    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "mongoose": "^9.6.2"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.4"
  },
  "keywords": [
    "url-shortener",
    "analytics"
